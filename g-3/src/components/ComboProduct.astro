---
import ResponsiveImage from './ResponsiveImage.astro';
import { Image } from 'astro:assets';
import { getFeaturedProductsByIds } from '../lib/collections';

// Fetch products at build time
const featuredProductIds = [1, 2, 3, 4, 5, 6, 7, 8];
const products = await getFeaturedProductsByIds(featuredProductIds);

const orderedProducts = featuredProductIds
  .map(id => products.find(p => p.id === id))
  .filter(p => p !== undefined);

function getDiscountPercentage(price: number, originalPrice?: number | null): number {
  if (!originalPrice || originalPrice <= price) return 0;
  return Math.round(((originalPrice - price) / originalPrice) * 100);
}
---

<section class="mx-10 py-8 bg-gray-100">
  <div>
    <h2 class="text-xl font-bold border-b-2 border-gray-300 pb-2 mb-6 uppercase">
      Sản phẩm ghế công thái học
    </h2>

    {/* Layout with banner (4 cols) left and 2 products right */}
    <div class="grid grid-cols-6 gap-4 mb-4">
      {/* Banner - takes 4 columns */}
      <div class="col-span-6 lg:col-span-4 relative h-[250px] lg:h-[400px] rounded-lg overflow-hidden">
        <Image
          src="/images/header-img.jpg"
          alt="Combo Sản Phẩm"
          class="object-cover w-full h-full"
          width={800}
          height={600}
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent flex flex-col justify-center pl-6 md:pl-12">
          <h3 class="text-white text-lg md:text-2xl font-bold mb-1">Nội Thất Văn Phòng</h3>
          <p class="text-white/90 text-xs md:text-sm max-w-md lg:max-w-lg">
            Nâng tầm không gian làm việc với bộ sưu tập nội thất văn phòng cao cấp, thiết kế hiện đại và tiện nghi
          </p>
          <a href="/categories" class="mt-3 inline-block bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors max-w-fit">
            Khám phá ngay
          </a>
        </div>
      </div>

      {/* First 2 products - takes 1 column each */}
      {orderedProducts.slice(0, 2).map((product) => {
        const discount = getDiscountPercentage(product.price, product.original_price);
        const imageUrl = product.image_url;
        return (
          <div class="col-span-3 lg:col-span-1">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col h-full overflow-hidden">
              <div class="aspect-square w-full relative group">
                {discount > 0 && (
                  <div class="absolute top-2 left-2 bg-red-600 text-white text-xs font-bold px-2 py-1 rounded-lg z-10">
                    -{discount}%
                  </div>
                )}
                <a href={`/san-pham/${product.slug}`}>
                  <ResponsiveImage
                    optimizedImages={(product as any)._optimized_image}
                    fallbackSrc={imageUrl}
                    alt={product.name}
                    class="object-contain w-full h-full cursor-pointer"
                    width={400}
                    height={400}
                  />
                </a>
              </div>
              <a href={`/san-pham/${product.slug}`} class="block">
                <div class="flex-1 flex flex-col px-2 pt-2 pb-1">
                  <div class="h-10 font-medium text-sm text-gray-900 line-clamp-2 mb-1">{product.name}</div>
                  <div class="flex items-end gap-2 mb-1 mt-auto">
                    <span class="text-red-600 font-bold text-base">{product.price.toLocaleString()}₫</span>
                    {product.original_price && (
                      <span class="text-xs text-gray-400 line-through">{product.original_price.toLocaleString()}₫</span>
                    )}
                  </div>
                  <div class="flex items-center justify-between gap-2 text-xs text-gray-500 mb-1">
                    <div class="flex items-center gap-2">
                      <span class="flex items-center gap-0.5">
                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <polygon points="9.9,1.1 7.6,6.6 1.6,7.3 6.1,11.2 4.8,17.1 9.9,14.1 15,17.1 13.7,11.2 18.2,7.3 12.2,6.6" />
                        </svg>
                        {(product.rating || 4.9).toFixed(1)}
                      </span>
                      <span>•</span>
                      <span>Đã bán {product.sold_count || 0}</span>
                    </div>
                    <button
                      class="p-1.5 bg-red-600 text-white rounded-full shadow hover:bg-red-700 transition-colors duration-200"
                      aria-label="Thêm vào giỏ hàng"
                      data-product-id={product.id}
                      data-product-name={product.name}
                      data-product-price={product.price}
                      data-product-image={product.image_url}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                    </button>
                  </div>
                </div>
              </a>
            </div>
          </div>
        );
      })}
    </div>

    {/* Row 2 with remaining products */}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {orderedProducts.slice(2).map((product) => {
        const discount = getDiscountPercentage(product.price, product.original_price);
        const imageUrl = product.image_url;
        return (
          <div>
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col h-full overflow-hidden">
              <div class="aspect-square w-full relative group">
                {discount > 0 && (
                  <div class="absolute top-2 left-2 bg-red-600 text-white text-xs font-bold px-2 py-1 rounded-lg z-10">
                    -{discount}%
                  </div>
                )}
                <a href={`/san-pham/${product.slug}`}>
                  <ResponsiveImage
                    optimizedImages={(product as any)._optimized_image}
                    fallbackSrc={imageUrl}
                    alt={product.name}
                    class="object-contain w-full h-full cursor-pointer"
                    width={400}
                    height={400}
                  />
                </a>
              </div>
              <a href={`/san-pham/${product.slug}`} class="block">
                <div class="flex-1 flex flex-col px-2 pt-2 pb-1">
                  <div class="h-10 font-medium text-sm text-gray-900 line-clamp-2 mb-1">{product.name}</div>
                  <div class="flex items-end gap-2 mb-1 mt-auto">
                    <span class="text-red-600 font-bold text-base">{product.price.toLocaleString()}₫</span>
                    {product.original_price && (
                      <span class="text-xs text-gray-400 line-through">{product.original_price.toLocaleString()}₫</span>
                    )}
                  </div>
                  <div class="flex items-center justify-between gap-2 text-xs text-gray-500 mb-1">
                    <div class="flex items-center gap-2">
                      <span class="flex items-center gap-0.5">
                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <polygon points="9.9,1.1 7.6,6.6 1.6,7.3 6.1,11.2 4.8,17.1 9.9,14.1 15,17.1 13.7,11.2 18.2,7.3 12.2,6.6" />
                        </svg>
                        {(product.rating || 4.9).toFixed(1)}
                      </span>
                      <span>•</span>
                      <span>Đã bán {product.sold_count || 0}</span>
                    </div>
                    <button
                      class="p-1.5 bg-red-600 text-white rounded-full shadow hover:bg-red-700 transition-colors duration-200"
                      aria-label="Thêm vào giỏ hàng"
                      data-product-id={product.id}
                      data-product-name={product.name}
                      data-product-price={product.price}
                      data-product-image={product.image_url}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                    </button>
                  </div>
                </div>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Add to cart functionality
  document.querySelectorAll('[data-product-id]').forEach(btn => {
    const button = btn as HTMLElement;
    button.addEventListener('click', (e) => {
      e.preventDefault();
      
      const product = {
        id: button.dataset.productId,
        name: button.dataset.productName,
        price: parseInt(button.dataset.productPrice || '0'),
        image_url: button.dataset.productImage,
      };

      // Get existing cart from localStorage
      const existingCart = JSON.parse(localStorage.getItem('cart') || '[]');
      
      // Check if product already exists in cart
      const existingItemIndex = existingCart.findIndex((item: any) => item.id === product.id);
      
      if (existingItemIndex > -1) {
        // Increment quantity if product already exists
        existingCart[existingItemIndex].quantity += 1;
      } else {
        // Add new product to cart
        existingCart.push({
          ...product,
          quantity: 1,
          image: product.image_url
        });
      }
      
      // Save back to localStorage
      localStorage.setItem('cart', JSON.stringify(existingCart));
      
      // Show success message
      alert('Đã thêm sản phẩm vào giỏ hàng!');
    });
  });
</script>
