---
import Layout from '../layouts/Layout.astro';
import HeroCarouselIsland from '../components/HeroCarouselIsland.astro';
import NewProducts from '../components/NewProducts.astro';
import ComboProduct from '../components/ComboProduct.astro';
import SupportSection from '../components/SupportSection.astro';
import HomeAdModal from '../components/HomeAdModal.astro';
---

<Layout 
  title="G-3.vn - Ghế Công Thái Học & Bàn Làm Việc Chất Lượng Cao"
  description="Cửa hàng chuyên cung cấp ghế công thái học, bàn nâng hạ điều chỉnh chiều cao chất lượng cao. Bảo hành chính hãng, giao hàng toàn quốc, tư vấn miễn phí."
  image="https://g-3.vn/images/og-default.jpg"
  imageAlt="G-3.vn - Ghế công thái học và bàn làm việc chất lượng cao"
  type="website"
  keywords={['G-3.vn', 'ghế công thái học', 'bàn nâng hạ', 'bàn làm việc', 'nội thất văn phòng', 'G3Tech', 'chất lượng cao', 'bảo hành chính hãng']}
  canonical="https://g-3.vn"
  showMobileHomeComponents={true}
>
  <!-- Desktop Content -->
  <div class="hidden md:block">
    <HeroCarouselIsland />
    <!-- <CategorySection /> -->
    <NewProducts />
    <ComboProduct />
    <SupportSection />
    <!-- <HomeAdModal /> -->
  </div>

  <!-- Mobile Content -->
  <div class="md:hidden">
    <!-- Mobile content will be handled by the mobile components in Layout -->
  </div>
</Layout>
