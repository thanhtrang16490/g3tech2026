              <h3 class="font-bold text-sm text-gray-800 mb-1">Miễn Phí Ship</h3>
              <p class="text-xs text-gray-600">Đơn từ 500K</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-all group">
