                <div class="bg-white/20 backdrop-blur-sm rounded-lg px-4 py-2 text-center min-w-[70px]">
                  <div class="text-3xl font-bold text-white" id="hours">04</div>
                  <div class="text-xs text-white/80 uppercase">Giờ</div>
                </div>
                <div class="bg-white/20 backdrop-blur-sm rounded-lg px-4 py-2 text-center min-w-[70px]">
                  <div class="text-3xl font-bold text-white" id="minutes">32</div>
                  <div class="text-xs text-white/80 uppercase">Phút</div>
                </div>
                <div class="bg-white/20 backdrop-blur-sm rounded-lg px-4 py-2 text-center min-w-[70px]">
                  <div class="text-3xl font-bold text-white" id="seconds">15</div>
                  <div class="text-xs text-white/80 uppercase">Giây</div>
                </div>
              </div>
            </div>
          </div>
          <a href="/products" class="bg-white text-yellow-600 hover:bg-gray-50 px-6 py-3 rounded-lg font-bold shadow-lg transition-all text-sm">
            Xem tất cả →
          </a>
        </div>
        
        {/* Products Grid */}
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
          {hotProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
        
        {/* Stock Progress Bar - Client-side only */}
        <div class="mt-8 bg-white/10 backdrop-blur-sm rounded-xl p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-white font-semibold text-sm">🔥 Đã bán <span id="sold-count">...</span> sản phẩm hôm nay</span>
            <span class="text-white font-bold text-sm">Chỉ còn <span id="remaining-count">...</span> suất ưu đãi</span>
          </div>
          <div class="bg-white/20 rounded-full h-3 overflow-hidden">
            <div id="stock-progress" class="bg-gradient-to-r from-yellow-400 to-white h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Featured Products -->
  <section class="py-12 bg-gray-50">
    <div class="container">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="bg-gradient-to-br from-red-500 to-orange-500 p-3 rounded-lg shadow-lg">
            <Icon name="star" class="w-6 h-6 text-white" />
          </div>
          <div>
            <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900">Sản Phẩm Nổi Bật</h2>
            <p class="text-gray-600 text-sm">Được khách hàng yêu thích nhất</p>
          </div>
        </div>
        <a href="/products" class="text-yellow-600 hover:text-yellow-700 font-semibold text-sm flex items-center gap-1">
          Xem tất cả
          <span>→</span>
        </a>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-5">
        {featuredProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Brand Logos Carousel -->
  <section class="py-12 bg-white border-y border-gray-200">
    <div class="container">
      <div class="text-center mb-8">
        <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mb-2 text-balance">Đối Tác Thương Hiệu</h2>
        <p class="text-gray-600 text-pretty">Cam kết 100% chính hãng từ các thương hiệu hàng đầu</p>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 items-center">
        <!-- Aqara -->
        <div class="bg-gray-50 rounded-xl p-6 flex items-center justify-center h-24 hover:shadow-lg transition-all group border border-gray-200">
          <div class="text-center">
            <div class="text-3xl mb-2">🏠</div>
            <div class="font-bold text-gray-800 group-hover:text-yellow-600 transition-colors">Aqara</div>
          </div>
        </div>
        
        <!-- Xiaomi -->
        <div class="bg-gray-50 rounded-xl p-6 flex items-center justify-center h-24 hover:shadow-lg transition-all group border border-gray-200">
          <div class="text-center">
