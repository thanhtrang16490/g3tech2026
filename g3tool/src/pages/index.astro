        </div>
      </div>
    </div>
  </section>

  <!-- Customer Reviews Section -->
  <section class="py-12 bg-gradient-to-br from-gray-50 to-white">
    <div class="container">
      <div class="text-center mb-10">
        <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900 mb-2 text-balance">Khách Hàng Nói Gì Về Chúng Tôi</h2>
