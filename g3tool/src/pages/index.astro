              <h3 class="font-bold text-sm text-gray-800 mb-1">Hỗ Trợ 24/7</h3>
              <p class="text-xs text-gray-600">Tư vấn miễn phí</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Flash Sale Section with Countdown Timer -->
  {hotProducts.length > 0 && (
    <section class="py-10 bg-gradient-to-r from-yellow-600 via-yellow-500 to-amber-500">
      <div class="container">
        <!-- Flash Sale Header -->
        <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between mb-8 gap-4">
          <div class="flex items-center gap-4">
            <div class="bg-white/20 backdrop-blur-sm p-4 rounded-xl">
              <span class="text-4xl">⚡</span>
            </div>
            <div>
              <div class="flex items-center gap-3 mb-1">
                <h2 class="text-3xl lg:text-4xl font-extrabold text-white">Flash Sale</h2>
                <span class="bg-white text-yellow-600 px-3 py-1 rounded-full text-sm font-bold animate-pulse">HOT</span>
              </div>
              <p class="text-white/90 text-base">Giảm giá sốc - Số lượng có hạn - Kết thúc sau:</p>
              
              {/* Countdown Timer */}
