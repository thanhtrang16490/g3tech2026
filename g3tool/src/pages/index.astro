            <span>Aqara Smart Lock N100</span>
          </div>
        </div>
        
        <!-- Review 3 -->
        <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-gradient-to-br from-green-500 to-emerald-500 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl">
              P
            </div>
