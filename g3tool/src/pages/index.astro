      </div>
      
      <!-- Stats -->
      <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl font-extrabold text-yellow-600 mb-2">500+</div>
          <div class="text-gray-600">Khách hàng hài lòng</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-yellow-600 mb-2">4.9/5</div>
