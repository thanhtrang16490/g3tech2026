---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Icon from '../components/Icon.astro';
import HeroCarousel from '../components/react/HeroCarousel';

// Workaround: Use import.meta.glob() to load JSON files directly
const productsRaw = import.meta.glob('../content/products/*.json', { eager: true });
const categoriesRaw = import.meta.glob('../content/categories/*.json', { eager: true });

// Convert to collection-like format
const allProducts = Object.entries(productsRaw).map(([path, module]) => {
  const id = path.split('/').pop().replace('.json', '');
  return {
    id,
    data: (module as any).default || module
  };
});

const allCategories = Object.entries(categoriesRaw).map(([path, module]) => {
  const id = path.split('/').pop().replace('.json', '');
  return {
    id,
    data: (module as any).default || module
  };
});

console.log('✅ Homepage - Loaded products:', allProducts.length);
console.log('✅ Homepage - Loaded categories:', allCategories.length);

// Filter products for different sections
const featuredProducts = allProducts.filter(p => p.data.featured || p.data.badge).slice(0, 8);
const newProducts = allProducts.filter(p => p.data.newArrival).slice(0, 8);
const hotProducts = allProducts
  .filter(p => p.data.originalPrice)
  .sort((a, b) => {
    const discountA = (a.data.originalPrice! - a.data.price) / a.data.originalPrice!;
    const discountB = (b.data.originalPrice! - b.data.price) / b.data.originalPrice!;
    return discountB - discountA;
  })
  .slice(0, 8);
---

<Layout title="G3Tool - Dụng Cụ Công Nghiệp, Thiết Bị Đo Lường, Điện Tử & 3D Printing Chính Hãng">
  <!-- Hero Section with Sidebar Menu - Inspired by thaihungsmarthome.com -->
  <section class="relative bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-12 gap-4 py-4">
        
        <!-- Left Sidebar - Category Menu with Hover Mega Menu (3 cols) -->
        <aside class="col-span-12 lg:col-span-3 relative">
          <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-gray-200">
            <!-- Sidebar Header -->
            <div class="bg-gradient-to-r from-yellow-600 via-yellow-500 to-amber-600 px-5 py-4">
              <h2 class="text-base font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                Danh mục sản phẩm
              </h2>
            </div>
            
            <!-- Category List -->
            <div class="max-h-[500px] overflow-y-auto">
              {allCategories.sort((a, b) => a.data.order - b.data.order).map((category) => {
                const categoryProducts = allProducts.filter(p => p.data.category === category.id).slice(0, 6);
                const productCount = allProducts.filter(p => p.data.category === category.id).length;
                return (
                  <div class="group relative border-b border-gray-100 last:border-b-0 hover:bg-gradient-to-r hover:from-red-50 hover:to-orange-50 transition-all">
                    <a 
                      href={`/products?category=${category.data.slug}`}
                      class="flex items-center gap-3 px-5 py-3.5 transition-all"
                    >
                      <span class="text-2xl group-hover:scale-125 transition-transform duration-300">{category.data.icon}</span>
                      <div class="flex-1 min-w-0">
                        <div class="font-semibold text-sm text-gray-800 group-hover:text-yellow-600 transition-colors truncate">
                          {category.data.name}
                        </div>
                        <div class="text-xs text-gray-500 group-hover:text-red-500 transition-colors">{productCount} sản phẩm</div>
                      </div>
                      <svg class="w-4 h-4 text-gray-400 group-hover:text-yellow-600 group-hover:translate-x-1 transition-all" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                      </svg>
                    </a>
                    
                    {/* Mega Menu - Appears on Hover - WIDER */}
                    {categoryProducts.length > 0 && (
                      <div class="absolute left-full top-0 ml-3 w-[750px] bg-white rounded-2xl shadow-2xl border-2 border-red-200 p-8 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
                        {/* Mega Menu Header */}
                        <div class="flex items-center justify-between mb-6 pb-4 border-b-2 border-gray-200">
                          <div class="flex items-center gap-4">
                            <div class="bg-gradient-to-br from-red-100 to-orange-100 p-4 rounded-xl">
                              <span class="text-4xl">{category.data.icon}</span>
                            </div>
                            <div>
                              <h3 class="text-xl font-bold text-gray-900">{category.data.name}</h3>
                              <p class="text-sm text-gray-600">{productCount} sản phẩmAvailable</p>
                            </div>
                          </div>
                          <a 
                            href={`/products?category=${category.data.slug}`}
                            class="bg-gradient-to-r from-red-600 to-orange-600 hover:from-red-700 hover:to-orange-700 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-lg hover:shadow-xl transition-all flex items-center gap-2"
                          >
                            Xem tất cả
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                          </a>
                        </div>
                        
                        {/* Products Grid - LARGER */}
                        <div class="grid grid-cols-3 gap-5">
                          {categoryProducts.map(product => (
                            <a 
                              href={`/products/${product.id}`}
                              class="group/product block bg-gray-50 rounded-xl p-4 hover:bg-red-50 hover:shadow-lg transition-all border border-gray-200 hover:border-red-300"
                            >
                              <div class="bg-white rounded-lg aspect-square mb-3 overflow-hidden shadow-sm">
                                <img 
                                  src={product.data.image} 
                                  alt={product.data.name}
                                  class="w-full h-full object-cover group-hover/product:scale-110 transition-transform duration-500"
                                  loading="lazy"
                                />
                              </div>
                              <div class="font-semibold text-sm text-gray-900 group-hover/product:text-yellow-600 transition-colors line-clamp-2 mb-2 min-h-[2.5rem]">
                                {product.data.name}
                              </div>
                              <div class="flex items-center gap-2 mb-2">
                                <span class="text-yellow-600 font-bold text-base">
                                  {new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.data.price)}
                                </span>
                                {product.data.originalPrice && (
                                  <span class="text-gray-400 line-through text-xs">
                                    {new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.data.originalPrice)}
                                  </span>
                                )}
                              </div>
                              {product.data.badge && (
                                <span class="inline-block px-3 py-1 bg-gradient-to-r from-red-600 to-orange-600 text-white text-xs rounded-lg font-semibold shadow-sm">
                                  {product.data.badge}
                                </span>
                              )}
                              {/* Rating */}
                              <div class="flex items-center gap-1 text-xs">
                                <div class="flex items-center">
                                  {Array.from({ length: 5 }, (_, i) => (
                                    <span class={i < Math.floor(product.data.rating) ? 'text-yellow-400' : 'text-gray-300'}>★</span>
                                  ))}
                                </div>
                                <span class="text-gray-500">({product.data.reviews})</span>
                              </div>
                            </a>
                          ))}
                        </div>
                        
                        {/* Arrow Indicator */}
                        <div class="absolute left-0 top-8 -ml-3 w-5 h-5 bg-white border-l-2 border-t-2 border-red-200 rotate-45"></div>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </aside>
        
        <!-- Main Content - Hero Carousel (9 cols) -->
        <div class="col-span-12 lg:col-span-9">
          <!-- React Hero Carousel -->
          <HeroCarousel client:load />
          
          <!-- Feature Cards Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-all group">
              <div class="text-3xl mb-2">✅</div>
              <h3 class="font-bold text-sm text-gray-800 mb-1">Chính Hãng</h3>
              <p class="text-xs text-gray-600">100% authentic</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-all group">
              <div class="text-3xl mb-2">🛡️</div>
              <h3 class="font-bold text-sm text-gray-800 mb-1">Bảo Hành 24T</h3>
              <p class="text-xs text-gray-600">Đổi mới hoàn toàn</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-all group">
