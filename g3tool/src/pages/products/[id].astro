---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import type { APIRoute } from 'astro';

// Use import.meta.glob() to load JSON files (workaround for getCollection bug)
const productsRaw = import.meta.glob('../../content/products/*.json', { eager: true });
const categoriesRaw = import.meta.glob('../../content/categories/*.json', { eager: true });

// Convert to collection-like format
const allProducts = Object.entries(productsRaw).map(([path, module]) => {
  const filename = path.split('/').pop()!.replace('.json', '');
  return {
    id: filename,
    data: (module as any).default
  };
});

const allCategories = Object.entries(categoriesRaw).map(([path, module]) => {
  const filename = path.split('/').pop()!.replace('.json', '');
  return {
    id: filename,
    data: (module as any).default
  };
});

// Generate static paths for all products
export function getStaticPaths() {
  const productsData = import.meta.glob('../../content/products/*.json', { eager: true });
  
  const products = Object.entries(productsData).map(([path, module]) => {
    const filename = path.split('/').pop()!.replace('.json', '');
    return {
      id: filename,
      data: (module as any).default
    };
  });
  
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

function formatPrice(price: number): string {
  if (price === 0) return 'Liên hệ';
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);
}

function getDiscount(original: number, current: number): number {
  return Math.round(((original - current) / original) * 100);
}

const category = allCategories.find(c => c.id === product.data.category);
const relatedProducts = allProducts.filter(p => p.data.category === product.data.category && p.id !== product.id).slice(0, 6);

// Generate multiple image URLs (in production, these would come from product data)
const productImages = [
  product.data.image,
  product.data.image, // Duplicate for demo - in real app, would be different angles
  product.data.image,
  product.data.image
];

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Trang chù",
      "item": "https://g3tool.vn/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Sản phẩm",
      "item": "https://g3tool.vn/products"
    },
    ...(category ? [{
      "@type": "ListItem",
      "position": 3,
      "name": category.data.name,
      "item": `https://g3tool.vn/products?category=${category.data.slug}`
    }] : []),
    {
      "@type": "ListItem",
      "position": category ? 4 : 3,
      "name": product.data.name,
      "item": `https://g3tool.vn/products/${product.id}`
    }
  ]
};

// Product Schema
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.data.name,
  "image": product.data.image,
  "description": product.data.description,
  "brand": {
    "@type": "Brand",
    "name": product.data.category.toUpperCase()
  },
  "offers": {
    "@type": "Offer",
    "url": `https://g3tool.vn/products/${product.id}`,
    "priceCurrency": "VND",
    "price": product.data.price,
    "priceValidUntil": "2026-12-31",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": product.data.rating,
    "reviewCount": product.data.reviews
  }
};
---

<Layout 
  title={`${product.data.name} - G3Tool`}
  description={product.data.description}
  image={product.data.image}
  canonicalUrl={`https://g3tool.vn/products/${product.id}`}
  structuredData={[breadcrumbSchema, productSchema]}
>
  <!-- Hero Product Section -->
  <section class="bg-gradient-to-br from-gray-50 via-white to-gray-100 text-gray-900 py-16">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="flex items-center space-x-2 text-sm text-gray-600 mb-10" aria-label="Breadcrumb">
        <a href="/" class="hover:text-red-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 rounded px-1 py-0.5">Trang chủ</a>
        <span class="text-gray-400">/</span>
        <a href="/products" class="hover:text-red-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 rounded px-1 py-0.5">Sản phẩm</a>
        <span class="text-gray-400">/</span>
        {category && (
          <>
            <a href={`/products?category=${category.data.slug}`} class="hover:text-red-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 rounded px-1 py-0.5">{category.data.name}</a>
            <span class="text-gray-400">/</span>
          </>
        )}
        <span class="text-gray-900 font-semibold truncate" aria-current="page">{product.data.name}</span>
      </nav>

      <!-- Bento Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Product Gallery - 7 columns -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Main Image with Soft Shadow -->
          <div class="relative bg-white rounded-3xl overflow-hidden shadow-2xl shadow-gray-300/50 aspect-square group">
            <img 
              id="main-product-image"
              src={productImages[0]} 
              alt={product.data.name} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="eager"
            />
            {product.data.badge && (
              <div class="absolute top-6 left-6 bg-gradient-to-r from-red-600 to-orange-600 text-white px-5 py-2.5 rounded-xl font-bold shadow-xl text-sm uppercase tracking-wide">
                {product.data.badge}
              </div>
            )}
            {product.data.originalPrice && (
              <div class="absolute top-6 right-6 bg-red-500 text-white px-4 py-2.5 rounded-xl font-bold shadow-xl text-sm">
                -{getDiscount(product.data.originalPrice, product.data.price)}%
              </div>
            )}
          </div>
                  
          <!-- Thumbnail Gallery with Hover Effects -->
          <div class="grid grid-cols-4 gap-4" id="thumbnail-gallery">
            {productImages.map((img, index) => (
              <button 
                class={`thumbnail bg-white rounded-2xl overflow-hidden border-2 transition-all duration-300 cursor-pointer aspect-square shadow-lg hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 ${index === 0 ? 'border-red-600 shadow-red-200' : 'border-gray-200 hover:border-red-400'}`}
                onclick={`showImage(${index})`}
                aria-label={`View image ${index + 1}`}
              >
                <img src={img} alt={`${product.data.name} - View ${index + 1}`} class="w-full h-full object-cover transition-transform duration-300 hover:scale-110" />
              </button>
            ))}
          </div>
        </div>

        <!-- Product Info - 5 columns -->
        <div class="lg:col-span-5 space-y-6">
          <h1 class="text-3xl lg:text-4xl font-extrabold leading-tight text-gray-900">{product.data.name}</h1>
          
          <!-- Rating & Stock Status -->
          <div class="flex items-center justify-between pb-6 border-b border-gray-200">
            <div class="flex items-center gap-4">
              <div class="flex items-center bg-yellow-50 px-4 py-2.5 rounded-xl border border-yellow-200">
                <div class="flex items-center">
                  {Array.from({ length: 5 }, (_, i) => (
                    <span class={i < Math.floor(product.data.rating) ? 'text-yellow-400 text-xl' : 'text-gray-300 text-xl'}>★</span>
                  ))}
                </div>
                <span class="text-gray-900 ml-3 font-bold">{product.data.rating}/5</span>
              </div>
              <span class="text-gray-600">({product.data.reviews} đánh giá)</span>
            </div>
            <span class="bg-green-50 text-green-700 px-4 py-2.5 rounded-xl font-semibold flex items-center gap-2 border border-green-200">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Còn hàng
            </span>
          </div>

          <!-- Price Box with Soft UI -->
          <div class="bg-gradient-to-r from-red-50 to-orange-50 p-6 rounded-2xl border-2 border-red-200 shadow-lg shadow-red-100/50">
            <div class="flex items-baseline gap-4 mb-3">
              <span class="text-red-600 font-extrabold text-4xl">{formatPrice(product.data.price)}</span>
              {product.data.originalPrice && (
                <span class="text-gray-500 line-through text-xl">{formatPrice(product.data.originalPrice)}</span>
              )}
            </div>
            {product.data.originalPrice && (
              <div class="flex items-center gap-3">
                <span class="bg-red-600 text-white px-4 py-2 rounded-xl font-bold text-sm uppercase tracking-wide">Tiết kiệm {getDiscount(product.data.originalPrice, product.data.price)}%</span>
                <span class="text-green-600 font-semibold text-sm">✓ Giá tốt nhất</span>
              </div>
            )}
          </div>

          <!-- Description -->
          <div class="prose max-w-none">
            <h3 class="text-xl font-bold mb-3 flex items-center gap-3 text-gray-900">
              <span class="text-red-600">📝</span>
              Mô tả sản phẩm
            </h3>
            <p class="text-gray-700 leading-relaxed">{product.data.description}</p>
          </div>

          <!-- Specifications with Icons -->
          <div>
            <h3 class="text-xl font-bold mb-4 flex items-center gap-3 text-gray-900">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Thông số kỹ thuật
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {product.data.specs.map((spec: string) => {
                // Icon mapping based on spec content
                const specLower = spec.toLowerCase();
                let iconSvg = '';
                let iconColor = 'text-blue-600';
                let bgColor = 'bg-blue-50';
                let borderColor = 'border-blue-200';
                
                // WiFi/Connectivity icons
                if (specLower.includes('wifi') || specLower.includes('wireless') || specLower.includes('802.11')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />';
                  iconColor = 'text-blue-600';
                  bgColor = 'bg-blue-50';
                  borderColor = 'border-blue-200';
                } else if (specLower.includes('bluetooth') || specLower.includes('ble')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.707 18.707l10.586-10.586M6.707 5.293l10.586 10.586M13 3v4h4l-8 14v-4H5l8-14z" />';
                  iconColor = 'text-indigo-600';
                  bgColor = 'bg-indigo-50';
                  borderColor = 'border-indigo-200';
                } else if (specLower.includes('zigbee') || specLower.includes('z-wave') || specLower.includes('thread')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />';
                  iconColor = 'text-cyan-600';
                  bgColor = 'bg-cyan-50';
                  borderColor = 'border-cyan-200';
                } else if (specLower.includes('ethernet') || specLower.includes('lan') || specLower.includes('rj45')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />';
                  iconColor = 'teal-600';
                  bgColor = 'bg-teal-50';
                  borderColor = 'border-teal-200';
                // Power/Electrical icons
                } else if (specLower.includes('power') || specLower.includes('electric') || specLower.includes('voltage') || specLower.includes('watt')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />';
                  iconColor = 'text-yellow-600';
                  bgColor = 'bg-yellow-50';
                  borderColor = 'border-yellow-200';
                } else if (specLower.includes('battery') || specLower.includes('mah') || specLower.includes('charging')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v4a1 1 0 001 1h3m8-5v4a1 1 0 01-1 1h-3m-6 5a1 1 0 01-1-1v-4m9 5a1 1 0 001-1v-4m-9 0h12m-12 0a4 4 0 01-4-4V7a4 4 0 014-4h12a4 4 0 014 4v4a4 4 0 01-4 4m-12 0a4 4 0 00-4 4v4a4 4 0 004 4h12a4 4 0 004-4v-4a4 4 0 00-4-4" />';
                  iconColor = 'text-green-600';
                  bgColor = 'bg-green-50';
                  borderColor = 'border-green-200';
                } else if (specLower.includes('usb') || specLower.includes('type-c') || specLower.includes('micro-usb')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />';
                  iconColor = 'text-blue-600';
                  bgColor = 'bg-blue-50';
                  borderColor = 'border-blue-200';
                // Sensor icons
                } else if (specLower.includes('pir') || specLower.includes('motion') || specLower.includes('sensor')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
                  iconColor = 'text-purple-600';
                  bgColor = 'bg-purple-50';
                  borderColor = 'border-purple-200';
                } else if (specLower.includes('light') || specLower.includes('lux') || specLower.includes('illumination')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />';
                  iconColor = 'text-yellow-600';
                  bgColor = 'bg-yellow-50';
                  borderColor = 'border-yellow-200';
                } else if (specLower.includes('temperature') || specLower.includes('celsius') || specLower.includes('fahrenheit')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />';
                  iconColor = 'text-red-600';
                  bgColor = 'bg-red-50';
                  borderColor = 'border-red-200';
                } else if (specLower.includes('humidity') || specLower.includes('moisture') || specLower.includes('%rh')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />';
                  iconColor = 'text-cyan-600';
                  bgColor = 'bg-cyan-50';
                  borderColor = 'border-cyan-200';
                // Camera/Video icons
                } else if (specLower.includes('camera') || specLower.includes('1080p') || specLower.includes('4k') || specLower.includes('resolution')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />';
                  iconColor = 'text-red-600';
                  bgColor = 'bg-red-50';
                  borderColor = 'border-red-200';
                } else if (specLower.includes('lens') || specLower.includes('focal') || specLower.includes('mm')) {
                  iconSvg = '<circle cx="12" cy="12" r="3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 1v2m0 18v2m9-9h-2M5 12H1m15.364 6.364l-1.414-1.414M7.05 7.05L5.636 5.636m12.728 0l-1.414 1.414M7.05 16.95l-1.414 1.414" />';
                  iconColor = 'text-pink-600';
                  bgColor = 'bg-pink-50';
                  borderColor = 'border-pink-200';
                } else if (specLower.includes('night vision') || specLower.includes('ir') || specLower.includes('infrared')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />';
                  iconColor = 'text-indigo-600';
                  bgColor = 'bg-indigo-50';
                  borderColor = 'border-indigo-200';
                // Protection/Durability icons
                } else if (specLower.includes('ip65') || specLower.includes('ip66') || specLower.includes('ip67')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />';
                  iconColor = 'text-green-600';
                  bgColor = 'bg-green-50';
                  borderColor = 'border-green-200';
                } else if (specLower.includes('waterproof') || specLower.includes('water') || specLower.includes('rain')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />';
                  iconColor = 'text-blue-600';
                  bgColor = 'bg-blue-50';
                  borderColor = 'border-blue-200';
                } else if (specLower.includes('impact') || specLower.includes('shock') || specLower.includes('resistant')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />';
                  iconColor = 'text-orange-600';
                  bgColor = 'bg-orange-50';
                  borderColor = 'border-orange-200';
                // Size/Weight icons
                } else if (specLower.includes('dimension') || specLower.includes('size') || specLower.includes('x') || specLower.includes('×')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />';
                  iconColor = 'text-emerald-600';
                  bgColor = 'bg-emerald-50';
                  borderColor = 'border-emerald-200';
                } else if (specLower.includes('weight') || specLower.includes('kg') || specLower.includes('gram')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 1a5.002 5.002 0 006.801 4.811l5.208 2.604a2.5 2.5 0 002.604-2.604l-2.604-5.208A5.002 5.002 0 0020.189 9L21 6m-9 0h6m-6 0a3 3 0 11-6 0m6 0V3" />';
                  iconColor = 'text-orange-600';
                  bgColor = 'bg-orange-50';
                  borderColor = 'border-orange-200';
                // Industrial Tools icons
                } else if (specLower.includes('home') || specLower.includes('house') || specLower.includes('building')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 12v10a2 2 0 002 2h10a2 2 0 002-2V12l-2-2m0 0l-5-5m-5 5l5-5" />';
                  iconColor = 'text-red-600';
                  bgColor = 'bg-red-50';
                  borderColor = 'border-red-200';
                } else if (specLower.includes('voice') || specLower.includes('alexa') || specLower.includes('google')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />';
                  iconColor = 'text-blue-600';
                  bgColor = 'bg-blue-50';
                  borderColor = 'border-blue-200';
                } else if (specLower.includes('app') || specLower.includes('ios') || specLower.includes('android')) {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />';
                  iconColor = 'text-green-600';
                  bgColor = 'bg-green-50';
                  borderColor = 'border-green-200';
                // Default check icon
                } else {
                  iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />';
                  iconColor = 'text-green-600';
                  bgColor = 'bg-green-50';
                  borderColor = 'border-green-200';
                }
                
                return (
                  <div class={`flex items-start gap-3 p-4 ${bgColor} rounded-xl border ${borderColor} hover:shadow-md transition-all duration-200 group`}>
