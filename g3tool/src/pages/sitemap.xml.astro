---
// Generate dynamic sitemap
const productsRaw = import.meta.glob('../content/products/*.json', { eager: true });
const products = Object.entries(productsRaw).map(([path, module]) => {
  const filename = path.split('/').pop()!.replace('.json', '');
  return {
    id: filename,
    slug: (module as any).default.slug || filename,
    updatedAt: (module as any).default.updatedAt || '2026-06-25'
  };
});

const site = 'https://g3tool.com';
---

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
        http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">
  
  <!-- Homepage -->
  <url>
    <loc>{site}/</loc>
    <lastmod>2026-06-25</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  
  <!-- Products Listing Page -->
  <url>
    <loc>{site}/products</loc>
    <lastmod>2026-06-25</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  
  <!-- About Page (if exists) -->
  <url>
    <loc>{site}/about</loc>
    <lastmod>2026-06-25</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  
  <!-- Contact Page (if exists) -->
  <url>
    <loc>{site}/contact</loc>
    <lastmod>2026-06-25</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  
  <!-- Product Detail Pages -->
  {products.map(product => (
    <url>
      <loc>{site}/products/{product.slug}</loc>
      <lastmod>{product.updatedAt}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
  ))}
  
</urlset>
