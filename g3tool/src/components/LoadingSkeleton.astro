---
// Loading Skeleton Component
// Use this to show placeholder content while data is loading

interface Props {
  type?: 'product' | 'category' | 'text';
  count?: number;
}

const { type = 'product', count = 1 } = Astro.props;
---

{type === 'product' && (
  <>
    {Array.from({ length: count }).map((_, i) => (
      <div class="bg-white rounded-lg shadow-md overflow-hidden animate-pulse">
        <div class="w-full h-64 bg-gradient-to-r from-gray-200 via-gray-100 to-gray-200 bg-[length:200%_100%] animate-[shimmer_1.5s_infinite]"></div>
        
        <div class="p-4">
          <div class="h-1.5 bg-gray-200 rounded-full w-3/4 mb-2 animate-pulse"></div>
          <div class="h-4 bg-gray-200 rounded mb-3 w-full"></div>
          <div class="h-4 bg-gray-200 rounded mb-3 w-5/6"></div>
          
          <div class="h-3 bg-gray-200 rounded mb-2 w-1/3"></div>
          
          <div class="h-6 bg-gray-200 rounded mb-3 w-1/2"></div>
          
          <div class="flex flex-col space-y-2">
            <div class="h-10 bg-gray-200 rounded-lg w-full"></div>
            <div class="h-10 bg-gray-200 rounded-lg w-full"></div>
          </div>
        </div>
      </div>
    ))}
  </>
)}

{type === 'category' && (
  <>
    {Array.from({ length: count }).map((_, i) => (
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 animate-pulse">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gray-200 rounded-full animate-pulse"></div>
            <div class="h-5 bg-gray-200 rounded w-32"></div>
          </div>
          <div class="h-4 bg-gray-200 rounded w-20"></div>
        </div>
        
        <div class="grid grid-cols-2 gap-3">
          {Array.from({ length: 4 }).map((_, j) => (
            <div class="bg-white rounded-lg p-3">
              <div class="w-full aspect-square bg-gray-200 rounded-lg mb-2 animate-pulse"></div>
              <div class="h-3 bg-gray-200 rounded w-full mb-1"></div>
              <div class="h-3 bg-gray-200 rounded w-2/3"></div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </>
)}

{type === 'text' && (
  <>
    {Array.from({ length: count }).map((_, i) => (
      <div class="space-y-3 animate-pulse">
        <div class="h-4 bg-gray-200 rounded w-full"></div>
        <div class="h-4 bg-gray-200 rounded w-5/6"></div>
        <div class="h-4 bg-gray-200 rounded w-4/6"></div>
      </div>
    ))}
  </>
)}

<style>
  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
</style>
