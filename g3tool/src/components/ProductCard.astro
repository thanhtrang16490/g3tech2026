---
// Support both old format and new Content Collections format
interface Product {
  id?: string;
  slug?: string;
  data?: {
    name: string;
    category: string;
    price: number;
    originalPrice?: number | null;
    image: string;
    badge?: string | null;
    rating: number;
    reviews: number;
    description: string;
    specs: string[];
  };
  // Old format (fallback)
  name?: string;
  category?: string;
  price?: number;
  originalPrice?: number | null;
  image?: string;
  badge?: string | null;
  rating?: number;
  reviews?: number;
  description?: string;
  specs?: string[];
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

// Helper to get product data from either format
const isContentCollection = 'data' in product && product.data;
const productId = product.id || product.slug || 'unknown';
const productName = isContentCollection ? product.data!.name : product.name || '';
const productCategory = isContentCollection ? product.data!.category : product.category || '';
const productPrice = isContentCollection ? product.data!.price : product.price || 0;
const productOriginalPrice = isContentCollection ? product.data!.originalPrice : product.originalPrice;
const productImage = isContentCollection ? product.data!.image : product.image || '/images/product-placeholder.svg';
const productBadge = isContentCollection ? product.data!.badge : product.badge;
const productRating = isContentCollection ? product.data!.rating : product.rating || 5;
const productReviews = isContentCollection ? product.data!.reviews : product.reviews || 0;
const productDescription = isContentCollection ? product.data!.description : product.description || '';
const productSpecs = isContentCollection ? product.data!.specs : product.specs || [];

function formatPrice(price: number): string {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);
}

function getDiscount(original: number, current: number): number {
  return Math.round(((original - current) / original) * 100);
}
---

<div 
  class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group relative"
  data-product-card
  data-product-name={productName}
  data-product-desc={productDescription}
>
  <div class="relative overflow-hidden">
    <a href={`/products/${productId}`}>
      <img 
        src={productImage} 
        alt={productName}
        class="w-full h-64 object-cover bg-gray-50 group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
        width="400"
        height="400"
      />
    </a>
    
    {/* Wishlist Button */}
    <button 
      class="absolute top-2 right-2 bg-white hover:bg-red-50 text-gray-600 hover:text-red-600 w-9 h-9 rounded-full shadow-md flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 z-10 focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:outline-none"
      aria-label="Thêm vào yêu thích"
      onclick="this.classList.toggle('text-red-600'); this.classList.toggle('bg-red-50');"
      onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click();}"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
    
    {/* Badges */}
    <div class="absolute top-2 left-2 flex flex-col gap-2">
      {productBadge && (
        <div class="bg-red-600 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg">
          {productBadge}
        </div>
      )}
      
      {/* Free Shipping Badge */}
      {productPrice >= 500000 && (
        <div class="bg-green-600 text-white px-2 py-1 rounded-full text-xs font-semibold shadow-lg flex items-center gap-1">
          <span>🚚</span>
          <span>Freeship</span>
        </div>
      )}
    </div>
    
    {/* Discount Badge */}
    {productOriginalPrice && (
      <div class="absolute bottom-2 left-2 bg-amber-500 text-white px-3 py-1.5 rounded-lg text-sm font-bold shadow-lg">
        -{getDiscount(productOriginalPrice, productPrice)}%
      </div>
    )}
    
    {/* Quick Add to Cart Button (Hover) */}
    <div class="absolute bottom-2 right-2 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
      <button 
        class="bg-gradient-to-r from-red-600 to-orange-600 hover:from-red-700 hover:to-orange-700 text-white px-4 py-2 rounded-lg font-semibold shadow-lg flex items-center gap-2 text-sm"
        onclick="window.location.href='https://zalo.me/0947776662?text=Tôi muốn mua: {productName}'"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        Mua ngay
      </button>
    </div>
  </div>
  
  <div class="p-4">
    {/* Stock Indicator - Client-side only */}
    <div class="mb-2 hidden" data-stock-indicator>
      <div class="flex items-center gap-2">
        <div class="flex-1 bg-gray-200 rounded-full h-1.5 overflow-hidden">
          <div class="bg-gradient-to-r from-orange-500 to-red-600 h-full rounded-full" style="width: 0%" data-stock-bar></div>
        </div>
        <span class="text-xs text-red-600 font-semibold whitespace-nowrap">Sắp hết hàng!</span>
      </div>
    </div>
    
    <a href={`/products/${productId}`} class="block group-hover:text-red-600 transition-colors">
      <h3 class="font-semibold text-lg mb-2 line-clamp-2 min-h-[3rem]">{productName}</h3>
    </a>
    
    <p class="text-gray-600 text-sm mb-3 line-clamp-2">{productDescription}</p>
    
    {/* Rating */}
    <div class="flex items-center mb-2">
      <div class="flex items-center">
        {Array.from({ length: 5 }, (_, i) => (
          <span class={`text-base ${i < Math.floor(productRating) ? 'text-yellow-400' : 'text-gray-300'}`} aria-hidden="true">★</span>
        ))}
      </div>
      <span class="text-sm text-gray-500 ml-2">({productReviews})</span>
      {productReviews > 0 && (
        <span class="ml-2 text-xs text-green-600 font-semibold" data-sales-count>✓ Đã bán ...</span>
      )}
    </div>
    
    {/* Price */}
    <div class="flex items-center space-x-2 mb-3">
      <span class="text-red-600 font-bold text-xl">{formatPrice(productPrice)}</span>
      {productOriginalPrice && (
        <span class="text-gray-400 line-through text-sm">{formatPrice(productOriginalPrice)}</span>
      )}
    </div>
  </div>
</div>

<script define:vars={{productId}}>
  // Initialize client-side only elements to prevent hydration mismatch
  function initProductCard() {
    const card = document.querySelector(`[data-product-card]`);
    if (!card) return;
    
    // Randomly show stock indicator (60% chance)
    const stockIndicator = card.querySelector('[data-stock-indicator]');
    const stockBar = card.querySelector('[data-stock-bar]');
    if (stockIndicator && stockBar && Math.random() > 0.4) {
      stockIndicator.classList.remove('hidden');
      const width = Math.floor(Math.random() * 40 + 20);
      stockBar.style.width = `${width}%`;
    }
    
    // Random sales count
    const salesCount = card.querySelector('[data-sales-count]');
    if (salesCount) {
      const sales = Math.floor(Math.random() * 50 + 10);
      salesCount.textContent = `✓ Đã bán ${sales}`;
    }
  }
  
  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductCard);
  } else {
    initProductCard();
  }
</script>
