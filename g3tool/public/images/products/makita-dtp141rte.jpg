<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <!-- Background -->
  <rect width="400" height="400" fill="#F8F9FA"/>
  
  <!-- Makita Brand Color Bar -->
  <rect x="0" y="0" width="400" height="8" fill="#0066B3"/>
  
  <!-- Icon Background -->
  <circle cx="200" cy="140" r="70" fill="#0066B3" opacity="0.1"/>
  <circle cx="200" cy="140" r="50" fill="#0066B3" opacity="0.15"/>
  
  <!-- Product Icon -->
  <text x="200" y="160" font-size="64" text-anchor="middle" font-family="Arial, sans-serif">🔩</text>
  
  <!-- Makita Logo Text -->
  <text x="200" y="230" font-size="28" font-weight="bold" text-anchor="middle" font-family="Arial, sans-serif" fill="#0066B3">MAKITA</text>
  
  <!-- Product Model -->
  <text x="200" y="270" font-size="22" font-weight="bold" text-anchor="middle" font-family="Arial, sans-serif" fill="#1F2937">DTP141RTE</text>
  
  <!-- Sublabel -->
  <text x="200" y="300" font-size="16" text-anchor="middle" font-family="Arial, sans-serif" fill="#6B7280">4 chế độ</text>
  
  <!-- Rating Badge -->
  <rect x="140" y="330" width="120" height="32" rx="16" fill="#0066B3"/>
  <text x="200" y="351" font-size="13" font-weight="bold" text-anchor="middle" font-family="Arial, sans-serif" fill="white">⭐ 5.0/5.0</text>
  
  <!-- Border -->
  <rect x="1" y="1" width="398" height="398" fill="none" stroke="#E5E7EB" stroke-width="2"/>
</svg>