---
/**
 * OptimizedImage Component
 * Uses Astro's built-in image optimization
 * 
 * Usage:
 * <OptimizedImage 
 *   src="/images/products/product.jpg"
 *   alt="Product name"
 *   width={400}
 *   height={400}
 *   loading="lazy"
 * />
 */

import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  format?: 'avif' | 'webp' | 'jpeg' | 'png';
  quality?: number;
}

const {
  src,
  alt,
  width = 400,
  height = 400,
  class: className = '',
  loading = 'lazy',
  format = 'webp',
  quality = 80,
} = Astro.props;

// If src is already a local path, use Astro Image
let optimizedImage;
if (typeof src === 'string' && src.startsWith('/')) {
  // For external images, we need to handle them differently
  // Local images will be automatically optimized by Astro
  optimizedImage = src;
} else if (typeof src === 'object') {
  // ImageMetadata from import
  optimizedImage = src;
}
---

{optimizedImage ? (
  <img
    src={optimizedImage}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    class={`w-full h-auto ${className}`}
  />
) : (
  <img
    src={src as string}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    class={`w-full h-auto ${className}`}
  />
)}
