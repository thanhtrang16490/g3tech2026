---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Liên Hệ - G3BOX | Hỗ Trợ 24/7" description="Liên hệ G3BOX để được tư vấn miễn phí về thiết bị nhà thông minh. Hotline: 094 777 6662. Showroom tại Hưng Yên.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-red-600 to-orange-600 text-white py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-extrabold mb-4">Liên Hệ Với Chúng Tôi</h1>
        <p class="text-xl">Đội ngũ tư vấn sẵn sàng hỗ trợ bạn 24/7</p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        <div class="text-center p-6 bg-gray-50 rounded-2xl hover:shadow-lg transition-shadow">
          <div class="bg-red-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-bold mb-2">Hotline</h3>
          <a href="tel:0947776662" class="text-red-600 font-semibold">094 777 6662</a>
        </div>

        <div class="text-center p-6 bg-gray-50 rounded-2xl hover:shadow-lg transition-shadow">
          <div class="bg-red-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z" />
              <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z" />
            </svg>
          </div>
          <h3 class="font-bold mb-2">Zalo</h3>
          <a href="https://zalo.me/0947776662" target="_blank" class="text-red-600 font-semibold">Chat ngay</a>
        </div>

        <div class="text-center p-6 bg-gray-50 rounded-2xl hover:shadow-lg transition-shadow">
          <div class="bg-red-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold mb-2">Showroom</h3>
          <p class="text-sm text-gray-600">Hưng Yên</p>
        </div>

        <div class="text-center p-6 bg-gray-50 rounded-2xl hover:shadow-lg transition-shadow">
          <div class="bg-red-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold mb-2">Giờ làm việc</h3>
          <p class="text-sm text-gray-600">8:00 - 21:00</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
