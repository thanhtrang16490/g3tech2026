---
import Layout from "../../layouts/Layout.astro";
import { getAllCategories, getProductsByCategoryId, getAllBrands, type CategoryEntry, type ProductEntry, type BrandEntry } from "../../lib/collections";
import CategoryPageWrapper from "../../components/react/CategoryPageWrapper";

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

interface Props {
  category: CategoryEntry;
}

const { slug } = Astro.params;
const { category } = Astro.props;

// Pre-fetch products data at build time for better performance
const allProducts = await getProductsByCategoryId(category.id);
const initialProducts: ProductEntry[] = allProducts;

// Gather brands that have products in this category
const allBrands = await getAllBrands();
const brandIds = [...new Set(allProducts.map((p) => p.brand_id).filter(Boolean))];
const brands: BrandEntry[] = allBrands.filter((b) => brandIds.includes(b.id));

const categoryInfo = {
  title: category?.title || slug || "Danh mục sản phẩm",
  description: category?.description,
  image_url: category?.image_url,
};

const title = `${categoryInfo.title} | G3 - Công Thái Học`;
const description =
  categoryInfo.description ||
  `Khám phá các sản phẩm thuộc danh mục ${categoryInfo.title} tại G3.vn. Nội thất công thái học, bảo hành 12 tháng, giao hàng toàn quốc.`;
---

<Layout
  title={title}
  description={description}
  image={categoryInfo.image_url
    ? `https://g-3.vn${categoryInfo.image_url.replace(/^\/g3tech\//, "/g3tech-otm/").replace(/\.(jpg|jpeg|png|webp)$/i, ".avif")}`
    : "https://g-3.vn/images/og-default.jpg"}
  imageAlt={`${categoryInfo.title} - G-3.vn`}
  type="website"
  keywords={[
    categoryInfo.title,
    "G-3.vn",
    "ghế công thái học",
    "bàn làm việc",
    "nội thất văn phòng",
    "chất lượng cao",
  ]}
  canonical={`https://g-3.vn/categories/${category?.slug || slug}`}
>
  <CategoryPageWrapper
    categorySlug={slug}
    categoryData={{ ...category, id: String(category.id), description: category.description ?? undefined, image_url: category.image_url ?? undefined }}
    initialProducts={initialProducts.map(p => {
      // Get optimized image if available
      const optimizedImages = (p as any)._optimized_image || [];
      const thumbnailImage = optimizedImages.length > 0 
        ? optimizedImages.find((img: any) => img.width === 200) || optimizedImages[0]
        : null;
  
      return { 
        ...p, 
        id: String(p.id), 
        brand_id: p.brand_id ? String(p.brand_id) : undefined, 
        pd_cat_id: p.pd_cat_id ? String(p.pd_cat_id) : undefined, 
        original_price: p.original_price ?? undefined, 
        image_url: p.image_url ?? undefined, 
        image_square_url: p.image_square_url ?? undefined,
        optimized_image_url: thumbnailImage?.path || undefined,
        rating: p.rating ?? undefined 
      };
    })}
    availableBrands={brands.map(b => ({ ...b, id: String(b.id) }))}
    client:idle
  />
</Layout>
