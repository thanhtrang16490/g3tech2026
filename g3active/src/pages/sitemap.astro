---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const allCategories = await getCollection('categories');

const mainPages = [
  { name: 'Trang chủ', href: '/', description: 'Trang chủ G3BOX - Thiết bị nhà thông minh' },
  { name: 'Sản phẩm', href: '/products', description: 'Tất cả sản phẩm nhà thông minh' },
  { name: 'Giới thiệu', href: '/gioi-thieu', description: 'Về G3BOX - Công nghệ nhà thông minh' },
  { name: 'Liên hệ', href: '/lien-he', description: 'Liên hệ G3BOX' },
  { name: 'FAQ', href: '/faq', description: 'Câu hỏi thường gặp' },
];

const policyPages = [
  { name: 'Chính sách bảo mật', href: '/chinh-sach-bao-mat', description: 'Chính sách bảo vệ thông tin cá nhân' },
  { name: 'Chính sách vận chuyển', href: '/chinh-sach-van-chuyen', description: 'Chính sách giao hàng toàn quốc' },
  { name: 'Chính sách bảo hành', href: '/bao-hanh', description: 'Bảo hành 24 tháng tất cả sản phẩm' },
  { name: 'Điều khoản sử dụng', href: '/dieu-khoan', description: 'Điều khoản và quy định sử dụng' },
];

const categories = allCategories.map(cat => ({
  name: cat.data.name,
  href: `/products?category=${cat.data.slug}`,
  description: `Sản phẩm ${cat.data.name.toLowerCase()}`,
  productCount: allProducts.filter(p => p.data.category === cat.id).length
}));

const featuredProducts = allProducts.filter(p => p.data.featured).slice(0, 8);
---

<Layout title="Sitemap - G3BOX" description="Sitemap G3BOX - Sơ đồ website thiết bị nhà thông minh">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-red-600 to-orange-600 text-white py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-extrabold mb-4">Sitemap</h1>
        <p class="text-xl">Sơ đồ website G3BOX</p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <!-- Main Pages -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <div class="bg-gradient-to-br from-red-500 to-orange-500 w-10 h-10 rounded-xl flex items-center justify-center text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          Trang chính
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {mainPages.map(page => (
            <a 
              href={page.href}
              class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-all hover:scale-105 group border border-gray-200"
            >
              <h3 class="font-bold text-lg text-gray-800 group-hover:text-red-600 transition-colors mb-2">{page.name}</h3>
              <p class="text-sm text-gray-600">{page.description}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Policy Pages -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <div class="bg-gradient-to-br from-blue-500 to-cyan-500 w-10 h-10 rounded-xl flex items-center justify-center text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          Chính sách & Điều khoản
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {policyPages.map(page => (
            <a 
              href={page.href}
              class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-all hover:scale-105 group border border-gray-200"
            >
              <h3 class="font-bold text-base text-gray-800 group-hover:text-red-600 transition-colors mb-2">{page.name}</h3>
              <p class="text-sm text-gray-600">{page.description}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Product Categories -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <div class="bg-gradient-to-br from-green-500 to-emerald-500 w-10 h-10 rounded-xl flex items-center justify-center text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          Danh mục sản phẩm
          <span class="text-base font-normal text-gray-500">({categories.length} danh mục)</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {categories.map(cat => (
            <a 
              href={cat.href}
              class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-all hover:scale-105 group border border-gray-200"
            >
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-bold text-base text-gray-800 group-hover:text-red-600 transition-colors">{cat.name}</h3>
                <span class="bg-red-100 text-red-600 text-xs font-bold px-3 py-1 rounded-full">{cat.productCount} SP</span>
              </div>
              <p class="text-sm text-gray-600">{cat.description}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Featured Products -->
      {featuredProducts.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
            <div class="bg-gradient-to-br from-orange-500 to-red-500 w-10 h-10 rounded-xl flex items-center justify-center text-white">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            Sản phẩm nổi bật
            <span class="text-base font-normal text-gray-500">({featuredProducts.length} sản phẩm)</span>
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {featuredProducts.map(product => (
              <a 
                href={`/products/${product.id}`}
                class="bg-white p-4 rounded-xl shadow-md hover:shadow-xl transition-all hover:scale-105 group border border-gray-200"
              >
                <div class="aspect-square rounded-lg overflow-hidden bg-gray-100 mb-3">
                  <img 
                    src={product.data.image} 
                    alt={product.data.name}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
                <h3 class="font-semibold text-sm text-gray-800 group-hover:text-red-600 transition-colors line-clamp-2 mb-2">{product.data.name}</h3>
                <div class="text-red-600 font-bold text-base">
                  {new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.data.price)}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Statistics -->
      <div class="bg-gradient-to-br from-red-600 to-orange-600 text-white rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-6">Thống kê website</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-4xl font-extrabold mb-2">{mainPages.length + policyPages.length}</div>
            <div class="text-sm opacity-90">Trang cố định</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-extrabold mb-2">{categories.length}</div>
            <div class="text-sm opacity-90">Danh mục</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-extrabold mb-2">{allProducts.length}</div>
            <div class="text-sm opacity-90">Sản phẩm</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-extrabold mb-2">{featuredProducts.length}</div>
            <div class="text-sm opacity-90">Nổi bật</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
