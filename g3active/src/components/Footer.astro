---
const phoneNumber = '0947776662';
const zaloUrl = 'https://zalo.me/0947776662';
const showroomAddress = 'Hà Nội, Việt Nam';
const companyInfo = {
  name: 'Công Ty Cổ Phần G3Active Việt Nam',
  taxCode: '0110907369',
  issuedBy: 'Sở KH & ĐT TP Hà Nội',
  issuedDate: '04/12/2024',
  headquarters: 'Hà Nội, Việt Nam'
};

const footerLinks = [
  {
    title: 'Products',
    links: [
      { name: 'Smart Wearables', href: '/products?category=smart-wearables' },
      { name: 'Sports Audio', href: '/products?category=sports-audio' },
      { name: 'Recovery Tech', href: '/products?category=recovery-tech' },
      { name: 'Personal Mobility', href: '/products?category=personal-mobility' },
      { name: 'Fitness Equipment', href: '/products?category=fitness-equipment' },
      { name: 'Outdoor Tech', href: '/products?category=outdoor-tech' }
    ]
  },
  {
    title: 'Activities',
    links: [
      { name: 'Running & Fitness', href: '/#running' },
      { name: 'Cycling & Mobility', href: '/#cycling' },
      { name: 'Gym & Training', href: '/#gym' },
      { name: 'Outdoor Adventure', href: '/#outdoor' },
      { name: 'Sports Recovery', href: '/#recovery' }
    ]
  },
  {
    title: 'Support',
    links: [
      { name: 'User Guides', href: '/#guides' },
      { name: 'Technical Specs', href: '/#specs' },
      { name: 'Warranty Policy', href: '/bao-hanh' },
      { name: 'Shipping Policy', href: '/chinh-sach-van-chuyen' },
      { name: 'FAQ', href: '/faq' }
    ]
  },
  {
    title: 'About',
    links: [
      { name: 'About Us', href: '/gioi-thieu' },
      { name: 'Community', href: '/#community' },
      { name: 'Contact', href: '/lien-he' },
      { name: 'Privacy Policy', href: '/chinh-sach-bao-mat' },
      { name: 'Terms of Use', href: '/dieu-khoan' }
    ]
  }
];

const workingHours = [
  { day: 'Thứ 2 - Thứ 6', hours: '8:00 - 21:00' },
  { day: 'Thứ 7', hours: '8:00 - 18:00' },
  { day: 'Chủ nhật', hours: '9:00 - 17:00' }
];
---

<!-- Footer -->
<footer class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white mt-16 overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-red-500 rounded-full mix-blend-multiply filter blur-3xl animate-float"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-orange-500 rounded-full mix-blend-multiply filter blur-3xl animate-float" style="animation-delay: 3s;"></div>
  </div>
  
  <div class="container relative z-10">
    <!-- Main Footer Content -->
    <div class="py-12 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-8 lg:gap-10">
      <!-- Company Info - Spans 2 columns -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <div class="flex items-center gap-3 mb-5 group">
          <div class="relative">
            <div class="bg-gradient-to-br from-red-600 via-red-500 to-orange-600 text-white px-4 py-2.5 rounded-xl shadow-lg group-hover:shadow-2xl transition-all group-hover:scale-105">
              <span class="text-2xl font-extrabold tracking-wider">G3ACTIVE</span>
            </div>
            <div class="absolute -top-1 -right-1 w-3 h-3 bg-green-400 rounded-full border-2 border-gray-900 animate-pulse"></div>
          </div>
        </div>
        
        <p class="text-gray-300 mb-5 text-sm leading-relaxed">
          Ứng dụng công nghệ giúp mọi người sống năng động, khỏe mạnh và hiệu quả hơn. 
          Hệ sinh thái công nghệ cho lối sống năng động hàng đầu Việt Nam.
        </p>
        
        <!-- Social Media Icons -->
        <div class="flex items-center gap-3 mb-5">
          <a href="#" class="group relative" title="Facebook">
            <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-2.5 rounded-lg group-hover:scale-110 transition-transform shadow-lg">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
          </a>
          <a href={zaloUrl} target="_blank" class="group relative" title="Zalo">
            <div class="bg-gradient-to-br from-blue-600 to-blue-700 p-2.5 rounded-lg group-hover:scale-110 transition-transform shadow-lg">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
              </svg>
            </div>
          </a>
          <a href="#" class="group relative" title="YouTube">
            <div class="bg-gradient-to-br from-red-500 to-red-600 p-2.5 rounded-lg group-hover:scale-110 transition-transform shadow-lg">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </div>
          </a>
        </div>
        
        <!-- Working Hours -->
        <div class="bg-gray-800/50 backdrop-blur-sm rounded-lg p-4 border border-gray-700/50">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h4 class="font-semibold text-sm">Giờ làm việc</h4>
          </div>
          <div class="space-y-2 text-xs text-gray-300">
            {workingHours.map(schedule => (
              <div class="flex justify-between items-center">
                <span class="text-gray-400">{schedule.day}</span>
                <span class="font-semibold text-white">{schedule.hours}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Footer Links - 4 columns -->
      {footerLinks.map((section, index) => (
        <div>
          <h4 class="text-sm font-bold mb-4 flex items-center gap-2">
            <span class="w-1 h-4 bg-gradient-to-b from-red-500 to-orange-500 rounded-full flex-shrink-0"></span>
            <span class="text-gray-100">{section.title}</span>
          </h4>
          <ul class="space-y-2.5">
            {section.links.map(link => (
              <li>
                <a 
                  href={link.href} 
                  class="text-gray-400 hover:text-white transition-all duration-200 group flex items-start gap-2 text-sm"
                >
                  <span class="text-red-500 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">→</span>
                  <span class="group-hover:translate-x-1 transition-transform">{link.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="mt-12 pt-8 border-t border-gray-800">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Company Legal Info -->
        <div class="lg:col-span-2">
          <div class="bg-gray-800/30 backdrop-blur-sm rounded-lg p-5 border border-gray-700/50 h-full">
            <h5 class="font-bold text-sm mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              <span class="text-gray-100">Thông tin pháp lý</span>
            </h5>
            <div class="space-y-1.5 text-xs text-gray-400">
              <p class="text-gray-200 font-semibold text-sm">{companyInfo.name}</p>
              <p>GPĐKKD: <span class="text-gray-300 font-mono">{companyInfo.taxCode}</span></p>
              <p>Cấp ngày: <span class="text-gray-300">{companyInfo.issuedDate}</span> bởi <span class="text-gray-300">{companyInfo.issuedBy}</span></p>
              <p class="mt-2 leading-relaxed">
                <span class="font-semibold text-gray-300">Trụ sở chính:</span> {companyInfo.headquarters}
              </p>
            </div>
          </div>
        </div>
        
        <!-- Contact Info -->
        <div>
          <div class="bg-gradient-to-br from-red-600/10 to-orange-600/10 backdrop-blur-sm rounded-lg p-5 border border-red-500/20 h-full">
            <h5 class="font-bold text-sm mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="text-gray-100">Liên hệ ngay</span>
            </h5>
            <div class="space-y-3">
              <a href={`tel:${phoneNumber}`} class="flex items-center gap-3 text-gray-300 hover:text-white group transition-all">
                <div class="bg-gradient-to-br from-red-500 to-red-600 p-2.5 rounded-lg group-hover:scale-110 transition-transform shadow-md">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <span class="font-semibold text-white">{phoneNumber}</span>
              </a>
              <a href={zaloUrl} target="_blank" class="flex items-center gap-3 text-gray-300 hover:text-white group transition-all">
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-2.5 rounded-lg group-hover:scale-110 transition-transform shadow-md">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                  </svg>
                </div>
                <span class="text-sm">Chat Zalo tư vấn</span>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="mt-8 pt-6 border-t border-gray-800/50 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-500">
        <p>© {new Date().getFullYear()} <span class="text-gray-400">{companyInfo.name}</span>. Tất cả quyền được bảo lưu.</p>
        <div class="flex items-center gap-3">
          <a href="/chinh-sach-bao-mat" class="hover:text-white transition-colors">Chính sách bảo mật</a>
          <span class="text-gray-700">•</span>
          <a href="/dieu-khoan" class="hover:text-white transition-colors">Điều khoản sử dụng</a>
          <span class="text-gray-700">•</span>
          <a href="/chinh-sach-van-chuyen" class="hover:text-white transition-colors">Vận chuyển</a>
          <span class="text-gray-700">•</span>
          <a href="/bao-hanh" class="hover:text-white transition-colors">Bảo hành</a>
        </div>
      </div>
    </div>
  </div>
</footer>
